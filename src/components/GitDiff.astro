---
import { Code } from '@astrojs/starlight/components';
import { diffLines } from 'diff';

interface Props {
  repo: string;
  commitA: string;
  commitB: string;
  file: string;
  lang: string;
  title?: string;
}

const { repo, commitA, commitB, file, lang, title } = Astro.props;

const baseUrl = 'https://raw.githubusercontent.com';
const urlA = `${baseUrl}/${repo}/${commitA}/${file}`;
const urlB = `${baseUrl}/${repo}/${commitB}/${file}`;

const [responseA, responseB] = await Promise.all([
  fetch(urlA),
  fetch(urlB)
]);

let diffContent = '';
let delLines: number[] = [];
let insLines: number[] = [];

if (!responseA.ok || !responseB.ok) {
  diffContent = `// Error fetching files:\n// ${urlA}\n// ${urlB}`;
} else {
  const contentA = await responseA.text();
  const contentB = await responseB.text();

  const changes = diffLines(contentA, contentB);

  const cleanLines: string[] = [];
  let lineA = 1;
  let lineB = 1;
  let displayLine = 1;

  for (const part of changes) {
    const lines = part.value.split('\n').filter(l => l !== '');

    for (const line of lines) {
      if (part.removed) {
        cleanLines.push(line);
        delLines.push(displayLine);
        lineA++;
        displayLine++;
      } else if (part.added) {
        cleanLines.push(line);
        insLines.push(displayLine);
        lineB++;
        displayLine++;
      } else {
        cleanLines.push(line);
        lineA++;
        lineB++;
        displayLine++;
      }
    }
  }

  diffContent = cleanLines.join('\n');
}
---

<Code 
  code={diffContent} 
  lang={lang} 
  del={delLines.length > 0 ? delLines : undefined} 
  ins={insLines.length > 0 ? insLines : undefined} 
  title={title || file} 
/>
