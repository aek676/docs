---
import { Code } from '@astrojs/starlight/components';
import type { ComponentProps } from 'astro/types';

interface Props extends Omit<ComponentProps<typeof Code>, 'code'> {
  url: string;
}

const { url, ...codeProps } = Astro.props;

const cleanUrl = url.replace(/[<>]/g, '');

const response = await fetch(cleanUrl);
let codeString = '';

if (response.ok) {
  codeString = await response.text();
} else {
  codeString = `// Error al cargar el archivo remoto desde: ${url}`;
}
---

<Code code={codeString} {...codeProps} />
